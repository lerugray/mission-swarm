# Simulation outputs — per-run JSON state, feeds, personas.
# Content may be strategically sensitive; keep local.
simulations/
!simulations/.gitkeep

# Drafts directory — not used unless creative_work_allowed flips on.
drafts/
!drafts/.gitkeep

# Secrets
.env
.env.*
!.env.example
*.key
*.pem

# Bun / Node
node_modules/
bun.lock
bun.lockb
dist/
build/
*.log

# Editor + OS cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.tmp

# Claude Code per-machine settings
.claude/settings.local.json

# Claude Design artifacts — preview HTML + React code land here on
# extract; not repo content (kept as local reference + mirrored to
# private-generalstaff/design-payloads/ for cross-machine access).
claude-design-output/
claude-design-output-markov/
mission-swarm.zip
missionswarmmarkov.zip

# GS state junction (private-state safety; defensive add 2026-04-30 per
# cross-project gitignore audit. The state/<id>/ junction may not exist
# locally yet, but if a bot cycle or Cursor session creates it later,
# git add -A would otherwise leak private MISSION.md / tasks.json content).
state/

# GS dispatcher per-project worktree — bot scratch space, never tracked.
.bot-worktree/
