# MissionSwarm environment configuration. Copy to .env and fill in.

# --- LLM provider (choose one) ---

# OpenRouter (default, cloud, requires API key)
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# MISSIONSWARM_LLM_MODEL=qwen/qwen3.5-32b-instruct

# Ollama (local, requires a running Ollama server — no GPU required
# for small models but slower)
# OLLAMA_BASE_URL=http://localhost:11434
# MISSIONSWARM_LLM_MODEL=qwen2.5:7b

# --- Simulation defaults (optional overrides) ---
# MISSIONSWARM_DEFAULT_AGENTS=20
# MISSIONSWARM_DEFAULT_ROUNDS=5
